# Mode DB: local, firebase, or supabase
VITE_DB_MODE=local

# Firebase configuration (required only when VITE_DB_MODE=firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase configuration (required only when VITE_DB_MODE=supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

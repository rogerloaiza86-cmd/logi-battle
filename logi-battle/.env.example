# ============================================================
# LOGI-BATTLE — Variables d'environnement
# ============================================================
# INSTRUCTIONS :
#   1. Copiez ce fichier et renommez-le en ".env"
#      (commande : cp .env.example .env)
#   2. Remplissez chaque valeur avec vos vraies clés
#   3. NE COMMITEZ JAMAIS le fichier .env dans Git !
# ============================================================

# --- Firebase (optionnel) ---
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# --- Base de données (firebase | supabase | local) ---
VITE_DB_MODE=local

# --- Supabase (optionnel) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Service IA pour la génération de questions (optionnel) ---
# Compatible avec OpenAI, Mistral, ou tout autre API OpenAI-compatible
# Si ces variables sont absentes, le générateur fonctionne en mode démo (questions fictives)
#
# Exemple OpenAI :
#   VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
#   VITE_AI_MODEL=gpt-4o-mini
#
# Exemple Mistral :
#   VITE_AI_API_URL=https://api.mistral.ai/v1/chat/completions
#   VITE_AI_MODEL=mistral-small-latest
#
VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
VITE_AI_API_KEY=sk-YOUR_AI_API_KEY_HERE
VITE_AI_MODEL=gpt-4o-mini

# ============================================================
# LOGI-BATTLE — Configuration de l'agent Python (kimi_agent.py)
# ============================================================
# INSTRUCTIONS :
#   1. Copiez ce fichier et renommez-le en ".env"
#      (commande : cp .env.example .env)
#   2. Remplissez chaque valeur avec vos vraies clés
#   3. NE COMMITEZ JAMAIS le fichier .env dans Git !
# ============================================================

# --- API Moonshot Kimi (agent de génération de code) ---
# Obtenez votre clé sur : https://platform.moonshot.cn/
KIMI_API_KEY=your_moonshot_api_key_here
KIMI_API_URL=https://api.moonshot.cn/v1
